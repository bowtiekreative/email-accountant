# Copy to .env.stack and fill in. Used by docker-compose AND the connectors.
# Generate secrets with: openssl rand -hex 32

# ── Paperless-ngx ──
PAPERLESS_DB_PASSWORD=changeme
PAPERLESS_SECRET_KEY=changeme-openssl-rand-hex-32
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme
# Connector → Paperless (create an API token in Paperless: Settings → API)
PAPERLESS_URL=http://localhost:8080
PAPERLESS_TOKEN=
PAPERLESS_ENABLED=true

# ── Akaunting (business) ──
AKAUNTING_DB_PASSWORD=changeme
AKAUNTING_DB_ROOT_PASSWORD=changeme
AKAUNTING_URL=http://localhost:8010
AKAUNTING_COMPANY_NAME=BowTie Kreative
AKAUNTING_EMAIL=you@example.com
AKAUNTING_PASSWORD=changeme
# Connector → Akaunting
AKAUNTING_TOKEN=
AKAUNTING_COMPANY_ID=1
AKAUNTING_ACCOUNT_ID=1
AKAUNTING_PAYMENT_METHOD=offline-payments.cash.1
AKAUNTING_ENABLED=true

# ── Firefly III (personal) ──
FIREFLY_DB_PASSWORD=changeme
# 32-char app key: head -c 32 /dev/urandom | base64
FIREFLY_APP_KEY=base64:changeme
FIREFLY_URL=http://localhost:8020
# Connector → Firefly (create a Personal Access Token in Firefly: Profile → OAuth)
FIREFLY_TOKEN=
FIREFLY_ASSET_ACCOUNT=Checking account
FIREFLY_ENABLED=true

# ── Strapi (orchestration) ──
STRAPI_DB_PASSWORD=changeme
STRAPI_APP_KEYS=key1,key2
STRAPI_API_TOKEN_SALT=changeme
STRAPI_ADMIN_JWT_SECRET=changeme
STRAPI_JWT_SECRET=changeme
STRAPI_TRANSFER_TOKEN_SALT=changeme
# Connector → Strapi (create a full-access API token in Strapi admin)
STRAPI_URL=http://localhost:1337
STRAPI_TOKEN=
STRAPI_ENABLED=true

# ── Routing (optional overrides; Strapi routing-rules win at runtime) ──
ROUTE_BUSINESS=akaunting
ROUTE_PERSONAL=firefly
ROUTE_UNKNOWN=firefly

# Where the email scanner's ledger lives (the ingestion source).
EMAIL_ACCOUNTANT_DB_DIR=/root/.email-accountant/data
