# Email Accountant - Deployment Configuration
# Add these to your GitHub repo:
#
# SECRETS (Settings → Secrets and variables → Actions → Secrets):
#   HOSTINGER_API_KEY = <your Hostinger API token>
#   POSTGRES_PASSWORD = <from gen_secrets.py>
#   JWT_SECRET = <from gen_secrets.py>
#   SECRET_KEY_BASE = <from gen_secrets.py>
#   ANON_KEY = <from gen_secrets.py>
#   SERVICE_ROLE_KEY = <from gen_secrets.py>
#
# VARIABLES (Settings → Variables):
#   HOSTINGER_VM_ID = 620544
#
# Then run: curl -X POST -H "Authorization: token YOUR_GITHUB_PAT" \
#   -H "Accept: application/vnd.github.v3+json" \
#   https://api.github.com/repos/bowtiekreative/email-accountant/dispatches \
#   -d '{"event_type":"workflow_dispatch"}'
#
# Or go to GitHub → Actions → build-images → Run workflow

