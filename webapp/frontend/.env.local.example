# Copy to .env.local.

# Point the UI at the backend (default shown). Leave unset to use the same-origin
# /api proxy (see next.config.mjs) when running behind one host.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# --- Supabase Auth (Google + email/password) ---
# Browser-safe values only. The PUBLISHABLE key is meant to be public; never put
# the secret key here. Must be prefixed NEXT_PUBLIC_ to reach the browser.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
