# Copy to .env (or export) before running the backend.

# Where the SQLite ledgers live (default shown). Matches db/database.py.
EMAIL_ACCOUNTANT_DB_DIR=$HOME/.email-accountant/data

# Earliest tax year the app offers (every year from here to now is selectable).
EMAIL_ACCOUNTANT_START_YEAR=2006

# "Scan recent" command (fast incremental). Defaults to the repo's daily scanner.
# EMAIL_ACCOUNTANT_SCAN_CMD=python /absolute/path/to/scan_daily.py

# "Full history" command (backfills 2006-onward). Defaults to the archive scanner.
# EMAIL_ACCOUNTANT_FULL_SCAN_CMD=python /absolute/path/to/scan_full_archive_fast.py

# Allowed frontend origin for CORS.
EMAIL_ACCOUNTANT_FRONTEND_ORIGIN=http://localhost:3000

# --- Cloud Supabase (auth + optional data engine) ---
# Auth: the backend verifies Supabase access-token JWTs against your project's
# published keys (JWKS). Set these to turn on Supabase login:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_JWKS_URL=https://xxxx.supabase.co/auth/v1/.well-known/jwks.json
# (legacy HS256 projects only) SUPABASE_JWT_SECRET=your-jwt-secret
#
# Data engine (scanner writes): point the engine at cloud Postgres. Supports the
# new key names (sb_secret_...) as well as the legacy service-role key:
# EMAIL_ACCOUNTANT_DB=supabase
# SUPABASE_SECRET_KEY=sb_secret_xxx          # or SUPABASE_SERVICE_KEY=...

# --- Ask AI assistant (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# LEDGER_ASSISTANT_MODEL=claude-sonnet-4-6   # optional override

# --- Gmail scanning (used by scan_daily.py) ---
# GMAIL_USER=you@example.com
# GMAIL_APP_PASSWORD=your-16-char-app-password

# --- Email reminders (reminders_cron.py / "Send digest") ---
# Either reuse the Gmail app password above, or set explicit SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# REMINDER_TO=you@example.com        # where the digest is sent
# REMINDER_FROM=you@example.com
